{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile and academic preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "academicStanding": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "number" },
        "plannedMajor": { "type": "string" },
        "cvSummary": { "type": "string" },
        "financialStatement": { "type": "string" }
      },
      "required": ["id", "email", "name", "academicStanding", "budget", "plannedMajor"]
    },
    "ShortlistItem": {
      "title": "ShortlistItem",
      "description": "A university added to the user's shortlist.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "country": { "type": "string" },
        "location": { "type": "string" },
        "fitReason": { "type": "string" },
        "tuitionFee": { "type": "number" },
        "entryRequirements": { "type": "string" },
        "scholarships": { "type": "array", "items": { "type": "string" } },
        "major": { "type": "string" },
        "userRank": { "type": "number" },
        "status": { "type": "string", "enum": ["shortlisted", "applying", "applied", "accepted", "rejected"] },
        "tasks": { "type": "array", "items": { "$ref": "Task" } }
      },
      "required": ["id", "name", "country", "location", "fitReason", "tuitionFee", "entryRequirements", "scholarships", "major", "userRank", "status", "tasks"]
    },
    "Task": {
      "title": "Task",
      "description": "A specific task in the application roadmap.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "deadline": { "type": "string" },
        "completed": { "type": "boolean" },
        "category": { "type": "string", "enum": ["preparation", "submission", "follow-up"] }
      },
      "required": ["id", "title", "description", "deadline", "completed", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles indexed by their Firebase Auth UID."
    },
    "/users/{userId}/shortlist/{shortlistId}": {
      "schema": "ShortlistItem",
      "description": "The user's university shortlist."
    }
  }
}
